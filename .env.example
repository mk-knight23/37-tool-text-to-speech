# MK VoiceKit — environment variables
# Copy to `.env.local` for local development. Every variable is OPTIONAL:
# with none set, the app builds and the text-to-speech workspace works fully in
# deterministic (non-AI) mode. Never commit real values — `.env*` is gitignored
# except this example.

# ---------------------------------------------------------------------------
# AI (Vercel AI Gateway) — powers the optional /api/ai/* tools
# ---------------------------------------------------------------------------

# Gateway credential. On Vercel this is provided automatically via OIDC on
# deploy, so you usually do NOT set it there. Set it locally (or on non-Vercel
# hosts) to enable the built-in AI tools. When absent AND no user BYOK key is
# sent, AI routes return a clean `ai_unavailable` error and the UI shows an
# honest degraded state — the rest of the app is unaffected.
AI_GATEWAY_API_KEY=

# Model gateway strings ("creator/model-name"). Changing a model is a config
# change, not a code change. Defaults are used when unset.
# Fast/default tier (simplify, summarize, translate, chapters, pronunciation):
AI_MODEL=anthropic/claude-haiku-4.5
# Higher-quality tier (rewrite, reading level, scripts, multi-speaker):
AI_MODEL_QUALITY=anthropic/claude-sonnet-4-5

# ---------------------------------------------------------------------------
# SEO
# ---------------------------------------------------------------------------

# Canonical base URL used for metadata, sitemap, and robots. Defaults to the
# production domain when unset.
NEXT_PUBLIC_SITE_URL=https://voicekit.mkazi.live

# ---------------------------------------------------------------------------
# Analytics (Google Tag Manager) — disabled unless set AND consented
# ---------------------------------------------------------------------------

# GTM container id (e.g. GTM-XXXXXX). Unset => no analytics script ever loads.
# Analytics also require explicit user consent and NODE_ENV=production.
NEXT_PUBLIC_GTM_ID=

# ---------------------------------------------------------------------------
# AdSense — prepared but disabled
# ---------------------------------------------------------------------------

# Ads are off unless this is exactly "true". No ad script loads while false.
NEXT_PUBLIC_ADSENSE_ENABLED=false
